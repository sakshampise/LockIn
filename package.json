{
    "name": "lockin-desktop",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "preview": "vite preview",
        "workflow:ai": "node scripts/workflows/generate-ai-insights.mjs",
        "workflow:weekly": "LOCKIN_WORKFLOW_MODE=weekly node scripts/workflows/generate-ai-insights.mjs",
        "workflow:dry-run": "node scripts/workflows/generate-ai-insights.mjs --dry-run",
        "graph:sync": "node scripts/graph/sync-neo4j.mjs"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.108.2",
        "clsx": "^2.1.1",
        "framer-motion": "^11.2.10",
        "jszip": "^3.10.1",
        "lucide-react": "^0.395.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "tailwind-merge": "^2.3.0"
    },
    "devDependencies": {
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "@typescript-eslint/eslint-plugin": "^7.13.0",
        "@typescript-eslint/parser": "^7.13.0",
        "@vitejs/plugin-react": "^4.3.1",
        "autoprefixer": "^10.4.19",
        "eslint": "^8.57.0",
        "eslint-plugin-react-hooks": "^4.6.2",
        "eslint-plugin-react-refresh": "^0.4.7",
        "postcss": "^8.4.38",
        "tailwindcss": "^3.4.4",
        "typescript": "^5.4.5",
        "vite": "^5.3.1"
    }
