# ─── Frontend (Browser-safe) ────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Enable the AI Coach UI (default: true in deployed environments).
# Set to 'false' locally until the ai-coach Edge Function is deployed.
VITE_AI_COACH_ENABLED=true

# Enable demo mode to populate the UI with realistic sample data
# for judging when real usage data is sparse (< 3 completed sessions).
VITE_DEMO_MODE=false

# ─── Server-only secrets (never expose through VITE_ variables) ──────────────
# Supabase service role key for server-side operations.
SUPABASE_SERVICE_ROLE_KEY=server-only-do-not-commit

# ─── Supabase Edge Function / Sarvam AI ──────────────────────────────────────
SARVAM_API_KEY=server-only-do-not-commit
SARVAM_MODEL=sarvam-30b

# ─── Render Workflow Runtime ──────────────────────────────────────────────────
# Caller verification secret (optional but recommended).
LOCKIN_WORKFLOW_SECRET=server-only-do-not-commit
RENDER_WORKFLOW_SECRET=server-only-do-not-commit

# User the scheduled workflow generates insights for.
LOCKIN_WORKFLOW_USER_ID=user-id-for-scheduled-insights
LOCKIN_WORKFLOW_USER_JWT=user-jwt-for-scheduled-insights

# Workflow mode: 'daily' or 'weekly' (default: daily)
LOCKIN_WORKFLOW_MODE=daily

# Custom workflow tracking name (default: lockin-daily-ai-summary)
LOCKIN_WORKFLOW_NAME=lockin-daily-ai-summary

# Comma-separated insight kinds override (leave blank to use mode defaults)
LOCKIN_AI_WORKFLOW_KINDS=

# Per-kind retry settings
LOCKIN_MAX_ATTEMPTS=3
LOCKIN_RETRY_DELAY_MS=2000

# ─── Optional Neo4j AuraDB Graph Intelligence ────────────────────────────────
# Application continues working when these are absent.
NEO4J_URI=https://your-aura-host.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=server-only-do-not-commit

# User to sync to the graph database
LOCKIN_GRAPH_USER_ID=user-id-to-sync
